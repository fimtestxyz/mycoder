#!/bin/bash
set -euo pipefail

# --------------------------
# Configuration (Local Only)
# --------------------------
LLM_MODEL="llama3:70b-instruct"  # Change to your local model
PROJECT_DIR="./autodev-generated"
OLLAMA_API_URL="http://localhost:11434/api/generate"  # Ollama's local API
MAX_TOKENS=8000
TEMPERATURE=0.2  # Lower = more deterministic code

# --------------------------
# Helper Functions
# --------------------------
function print_banner() {
  echo -e "\033[1;34m=============================================="
  echo -e "          Local AutoDev (Ollama + Bash)        "
  echo -e "==============================================\033[0m"
}

function validate_ollama() {
  if ! curl -s "$OLLAMA_API_URL" > /dev/null 2>&1; then
    echo -e "\033[1;31mError: Ollama is not running! Start it with: ollama serve\033[0m"
    exit 1
  fi

  # Check if model exists locally
  if ! ollama list | grep -q "$LLM_MODEL"; then
    echo -e "\033[1;33mModel $LLM_MODEL not found. Pulling it now...\033[0m"
    ollama pull "$LLM_MODEL"
  fi
}

function get_project_spec() {
  echo -e "\033[1;32mEnter a detailed description of the software project to generate:\033[0m"
  echo -e "Example: 'A CLI todo app in Python with SQLite storage, add/delete/list features'\n"
  read -r PROJECT_SPEC
  if [[ -z "$PROJECT_SPEC" ]]; then
    echo -e "\033[1;31mError: Project specification cannot be empty\033[0m"
    exit 1
  fi
}

function generate_project_structure() {
  echo -e "\n\033[1;32mGenerating project structure...\033[0m"
  
  # Prompt Ollama to generate a complete project (structured response)
  PROMPT=$(cat <<EOF
You are a senior software engineer tasked with creating a COMPLETE, RUNNABLE software project from scratch.
Follow these rules STRICTLY:
1. Output ONLY valid JSON with 2 keys: "structure" (directory/file tree as string) and "files" (object of file paths → content)
2. All code must be production-ready, well-commented, and follow best practices
3. Include all necessary files (README, requirements.txt, main code, tests, etc.)
4. Ensure NO external dependencies that require internet access (use local libraries only)
5. Make the project fully autonomous (runs without user intervention)

Project Requirements: $PROJECT_SPEC
EOF
  )

  # Call Ollama API (local) and capture response
  RESPONSE=$(curl -s -X POST "$OLLAMA_API_URL" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg model "$LLM_MODEL" --arg prompt "$PROMPT" --arg max_tokens "$MAX_TOKENS" --arg temperature "$TEMPERATURE" '{
      model: $model,
      prompt: $prompt,
      max_tokens: ($max_tokens | tonumber),
      temperature: ($temperature | tonumber),
      stream: false,
      format: "json"
    }')" | jq -r '.response')

  # Validate JSON response
  if ! echo "$RESPONSE" | jq . > /dev/null 2>&1; then
    echo -e "\033[1;31mError: Invalid JSON response from LLM\033[0m"
    echo "Raw response: $RESPONSE"
    exit 1
  fi

  # Create project directory
  rm -rf "$PROJECT_DIR"
  mkdir -p "$PROJECT_DIR"

  # Generate directory structure
  echo -e "\033[1;32mCreating directory structure...\033[0m"
  STRUCTURE=$(echo "$RESPONSE" | jq -r '.structure')
  echo "Project Structure:\n$STRUCTURE"

  # Create all files from LLM response
  echo -e "\n\033[1;32mWriting project files...\033[0m"
  echo "$RESPONSE" | jq -r '.files | to_entries[] | "\(.key)|\(.value)"' | while IFS='|' read -r FILE_PATH CONTENT; do
    # Skip empty paths/content
    if [[ -z "$FILE_PATH" || "$CONTENT" == "null" ]]; then continue; fi
    
    # Create parent directories
    FILE_ABS_PATH="$PROJECT_DIR/$FILE_PATH"
    mkdir -p "$(dirname "$FILE_ABS_PATH")"
    
    # Write content to file
    echo "$CONTENT" > "$FILE_ABS_PATH"
    echo "✅ Created: $FILE_ABS_PATH"
  done

  # Make executable files runnable
  find "$PROJECT_DIR" -type f -name "*.sh" -o -name "*.py" -o -name "*.js" | xargs chmod +x 2>/dev/null || true

  echo -e "\n\033[1;32m✅ Project generated successfully at: $PROJECT_DIR\033[0m"
  echo -e "\033[1;33mNext steps:\033[0m"
  echo "1. cd $PROJECT_DIR"
  echo "2. Follow instructions in README.md to run the project"
}

# --------------------------
# Main Workflow
# --------------------------
print_banner
validate_ollama
get_project_spec
generate_project_structure

