{
  "version": "1.0",
  "backend": {
    "base_url": "http://localhost:8000",
    "endpoints": [
      {
        "method": "GET",
        "path": "/docs",
        "expect_status": 200
      },
      {
        "method": "GET",
        "path": "/todos",
        "expect_status": 200,
        "expect_body_type": "array"
      },
      {
        "method": "POST",
        "path": "/todos",
        "expect_status": [
          200,
          201
        ],
        "request_body": {
          "title": "UAT todo",
          "name": "UAT todo"
        },
        "expect_body_keys": [
          "id"
        ]
      },
      {
        "method": "DELETE",
        "path": "/todos/{id}",
        "expect_status": [
          200,
          204
        ]
      }
    ]
  },
  "frontend": {
    "base_url": "http://localhost:5173",
    "checks": [
      {
        "path": "/",
        "expect_status": 200,
        "expect_html_contains": [
          "<div id=\"root\"",
          "<!DOCTYPE"
        ]
      }
    ]
  }
}